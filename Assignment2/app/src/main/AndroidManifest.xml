<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.assignment2">
    <!-- Permissions -->
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="true"
        android:theme="@style/Theme.AppCompat.Light.NoActionBar">
        <activity
            android:name=".BaseActivity"
            android:exported="false" />
        <!-- Shared Preferences -->
        <activity
            android:name=".SharedPrefActivity"
            android:exported="false" /> <!-- Intent (Implicit & Explicit) -->
        <activity
            android:name=".IntentActivity"
            android:exported="false" /> <!-- WebView Browser -->
        <activity
            android:name=".BrowserActivity"
            android:exported="false" /> <!-- ❌ REMOVE THIS (wrong duplicate / not needed) -->
        <!-- <activity android:name=".Browser" /> -->
        <!-- Notification -->
        <activity
            android:name=".NotificationActivity"
            android:exported="false" /> <!-- Contacts -->
        <activity
            android:name=".ContactsActivity"
            android:exported="false" /> <!-- Registration -->
        <activity
            android:name=".RegistrationActivity"
            android:exported="false" /> <!-- Main Activity (Launcher) -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>